<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monitor Sísmico Multi-Fuente</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        body {
            display: flex;
            height: 100vh;
            background-color: #121212;
            color: #fff;
        }
        #sidebar {
            width: 380px;
            background-color: #1e1e1e;
            padding: 20px;
            display: flex;
            flex-direction: column;
            box-shadow: 3px 0 15px rgba(0,0,0,0.7);
            z-index: 10;
        }
        h1 {
            font-size: 1.4rem;
            margin-bottom: 5px;
            color: #ff4d4d;
        }
        #status-container {
            font-size: 0.8rem;
            background: #2a2a2a;
            padding: 8px;
            border-radius: 4px;
            margin-bottom: 15px;
            border: 1px solid #333;
        }
        .source-badge {
            display: inline-block;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 0.7rem;
            font-weight: bold;
            margin-top: 4px;
        }
        .bg-usgs { background-color: #4caf50; color: white; }
        .bg-emsc { background-color: #2196f3; color: white; }

        #earthquake-list {
            flex: 1;
            overflow-y: auto;
            margin-top: 10px;
        }
        .eq-item {
            background: #282828;
            padding: 12px;
            margin-bottom: 8px;
            border-radius: 6px;
            cursor: pointer;
            border-left: 5px solid #ccc;
            transition: background 0.2s;
        }
        .eq-item:hover {
            background: #333;
        }
        .mag-high { border-left-color: #ff4d4d; }
        .mag-med { border-left-color: #ffa500; }
        .mag-low { border-left-color: #00ffcc; }

        #map {
            flex: 1;
            height: 100%;
        }
    </style>
</head>
<body>

    <div id="sidebar">
        <h1>⚠️ Monitor Global Pro</h1>
        <div id="status-container">
            <div id="usgs-status">USGS: Conectando...</div>
            <div id="emsc-status">EMSC: Conectando...</div>
        </div>
        <h3>Últimos Eventos Combinados</h3>
        <div id="earthquake-list">Sincronizando fuentes...</div>
    </div>

    <div id="map"></div>

    <script>
        let map;
        let markers = [];
        let globalEarthquakesMap = new Map(); // Para evitar sismos duplicados

        const USGS_URL = "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/2.5_hour.geojson";
        // API en tiempo real del EMSC filtrado por sismos recientes
        const EMSC_URL = "https://www.seismicportal.eu/fdsnws/event/1/query?limit=50&format=json";

        function initMap() {
            map = new google.maps.Map(document.getElementById("map"), {
                center: { lat: 20, lng: -20 }, 
                zoom: 3,
                styles: [
                    { elementType: "geometry", stylers: [{ color: "#1f1f1f" }] },
                    { elementType: "labels.text.stroke", stylers: [{ color: "#1f1f1f" }] },
                    { elementType: "labels.text.fill", stylers: [{ color: "#746855" }] },
                    { featureType: "water", elementType: "geometry", stylers: [{ color: "#0f1621" }] },
                    { featureType: "road", elementType: "geometry", stylers: [{ color: "#2c333d" }] }
                ]
            });

            // Actualización inicial y bucle cada 30 segundos
            updateAllSources();
            setInterval(updateAllSources, 30000);
        }

        async function updateAllSources() {
            // Limpiar el mapa y reiniciar el mapa de datos temporal
            clearMarkers();
            globalEarthquakesMap.clear();

            // Ejecutar ambas llamadas en paralelo para máxima velocidad
            await Promise.all([
                fetchUSGS(),
                fetchEMSC()
            ]);

            renderEarthquakes();
        }

        async function fetchUSGS() {
            try {
                const res = await fetch(USGS_URL);
                const data = await res.json();
                document.getElementById("usgs-status").innerText = `🟢 USGS: OK (${new Date().toLocaleTimeString()})`;
                
                data.features.forEach(f => {
                    const id = f.id || f.properties.net + f.properties.code;
                    globalEarthquakesMap.set(id, {
                        id: id,
                        mag: f.properties.mag,
                        place: f.properties.place,
                        time: f.properties.time,
                        lat: f.geometry.coordinates[1],
                        lng: f.geometry.coordinates[0],
                        source: "USGS"
                    });
                });
            } catch (e) {
                document.getElementById("usgs-status").innerText = "🔴 USGS: Error de conexión";
            }
        }

        async function fetchEMSC() {
            try {
                const res = await fetch(EMSC_URL);
                const data = await res.json();
                document.getElementById("emsc-status").innerText = `🟢 EMSC: OK (${new Date().toLocaleTimeString()})`;
                
                data.features.forEach(f => {
                    const id = f.id || f.properties.source_id;
                    // El EMSC a veces reporta sismos que ya tiene la USGS. 
                    // Si el ID o la proximidad extrema ya existe, lo ignoramos para no duplicar marcadores.
                    if (!globalEarthquakesMap.has(id)) {
                        globalEarthquakesMap.set(id, {
                            id: id,
                            mag: f.properties.mag,
                            place: f.properties.flynn_region || f.properties.text,
                            time: new Date(f.properties.time).getTime(),
                            lat: f.geometry.coordinates[1],
                            lng: f.geometry.coordinates[0],
                            source: "EMSC"
                        });
                    }
                });
            } catch (e) {
                document.getElementById("emsc-status").innerText = "🔴 EMSC: Error de conexión";
            }
        }

        function renderEarthquakes() {
            const listContainer = document.getElementById("earthquake-list");
            listContainer.innerHTML = "";

            // Ordenar todos los sismos combinados del más reciente al más antiguo
            const sortedQuakes = Array.from(globalEarthquakesMap.values())
                .sort((a, b) => b.time - a.time);

            if (sortedQuakes.length === 0) {
                listContainer.innerHTML = "<p>Buscando sismos en las redes...</p>";
                return;
            }

            sortedQuakes.forEach(quake => {
                let colorClass = "mag-low";
                let markerColor = "#00ffcc";

                if (quake.mag >= 6.0) {
                    colorClass = "mag-high";
                    markerColor = "#ff4d4d";
                } else if (quake.mag >= 4.5) {
                    colorClass = "mag-med";
                    markerColor = "#ffa500";
                }

                // Generar elemento visual en la barra de tareas
                const item = document.createElement("div");
                item.className = `eq-item ${colorClass}`;
                item.innerHTML = `
                    <strong>Mag: ${quake.mag.toFixed(1)}</strong> - ${quake.place}<br>
                    <small>${new Date(quake.time).toLocaleTimeString()}</small> 
                    <span class="source-badge ${quake.source === 'USGS' ? 'bg-usgs' : 'bg-emsc'}">${quake.source}</span>
                `;
                
                item.addEventListener("click", () => {
                    map.setCenter({ lat: quake.lat, lng: quake.lng });
                    map.setZoom(7);
                });
                listContainer.appendChild(item);

                // Dibujar en Google Maps
                const marker = new google.maps.Marker({
                    position: { lat: quake.lat, lng: quake.lng },
                    map: map,
                    icon: {
                        path: google.maps.SymbolPath.CIRCLE,
                        scale: Math.max(quake.mag * 2.5, 4), 
                        fillColor: markerColor,
                        fillOpacity: 0.5,
                        strokeWeight: 1,
                        strokeColor: "#ffffff"
                    }
                });

                const infowindow = new google.maps.InfoWindow({
                    content: `<div><strong>Fuente:</strong> ${quake.source}<br><strong>Magnitud:</strong> ${quake.mag}<br><strong>Lugar:</strong> ${quake.place}</div>`
                });

                marker.addListener("click", () => infowindow.open(map, marker));
                markers.push(marker);
            });
        }

        function clearMarkers() {
            markers.forEach(m => m.setMap(null));
            markers = [];
        }
    </script>

    <!-- REEMPLAZA TU_API_KEY_DE_GOOGLE CON TU CLAVE REAL DE GOOGLE MAPS -->
    <script src="https://maps.googleapis.com/maps/api/js?key=TU_API_KEY_DE_GOOGLE&callback=initMap" async defer></script>
</body>
</html>
